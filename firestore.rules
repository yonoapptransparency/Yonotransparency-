rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to verify if user is authorized as an admin (via database index lookup or owner fallback)
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == 'defentechscholar@gmail.com' ||
              exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
              exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public reading of non-sensitive store data
    // Restrict sensitive secure links and vault maps strictly to authorized administrators
    match /store_data/{docId} {
      allow read: if (docId != 'secure_links' && docId != 'sec_vault' && docId != 'sec_git_config') || isAdmin();
      allow write: if isAdmin();
    }
    
    // Support for metadata or other collections if they exist
    match /sec_git/{docId} {
      allow read, write: if isAdmin();
    }

    match /apps/{appId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /admins/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
